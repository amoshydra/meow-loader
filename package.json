{
  "name": "meow-loader",
  "version": "0.1.0",
  "description": "Download M3U8/HLS video streams and merge into MP4",
  "type": "module",
  "bin": {
    "meow-loader": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build index.ts --outdir dist --target node --minify",
    "prepack": "pnpm run build",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "generate-fixtures": "node --experimental-vm-modules scripts/generate-fixtures.js"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5",
    "vitest": "^2.0.0"
  }
}
